{
  "multipart": [
    {
      "apply": {
        "model": "mcwaterslides:block/water_conduit_core"
      }
    },
    {
      "when": {
        "north": "true"
      },
      "apply": {
        "model": "mcwaterslides:block/water_conduit_arm"
      }
    },
    {
      "when": {
        "south": "true"
      },
      "apply": {
        "model": "mcwaterslides:block/water_conduit_arm",
        "y": 180
      }
    },
    {
      "when": {
        "east": "true"
      },
      "apply": {
        "model": "mcwaterslides:block/water_conduit_arm",
        "y": 90
      }
    },
    {
      "when": {
        "west": "true"
      },
      "apply": {
        "model": "mcwaterslides:block/water_conduit_arm",
        "y": 270
      }
    },
    {
      "when": {
        "up": "true"
      },
      "apply": {
        "model": "mcwaterslides:block/water_conduit_arm",
        "x": 270
      }
    },
    {
      "when": {
        "down": "true"
      },
      "apply": {
        "model": "mcwaterslides:block/water_conduit_arm",
        "x": 90
      }
    }
  ]
}
